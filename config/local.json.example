{
  "_comment": "Copy this file to config/local.json (which is gitignored) on any machine that needs overrides. Same shape as machines.json: keyed by hostname, plus an optional 'default'. Values here override machines.json for THIS machine only and never sync to GitHub. Use for diverging absolute paths, the rig -> knight push target, or anything secret.",
  "_deposit_note": "push_target may be an ssh alias from ~/.ssh/config (e.g. 'l5gn-castle:vault/estates', home-relative), which both rsync and scp resolve. push_transport is auto-picked (scp on Windows, rsync elsewhere); set it explicitly only to override.",
  "LucasGoonPC": {
    "push_target": "l5gn-castle:vault/estates",
    "push_transport": "scp"
  },
  "_roots_note": "roots entries may be a bare path, or {'path': ..., 'scope': 'l5gn'|'mcf'}. The scope tag is what gives a project its registry scope (DECISIONS 0012) -- declared on the producer's root, never inferred from folder nesting, so no rig has to reorganise its folders. Untagged roots still scan; their projects land as scope 'other' and appear under DEPOSIT GAPS in build_registry --report-aliases.",
  "RENAME-ME-WORK-LAPTOP": {
    "roots": [
      {"path": "D:/Work/Github/MCF", "scope": "mcf"},
      {"path": "D:/Work/Github/L5GN", "scope": "l5gn"}
    ]
  },
  "_knight_example": {
    "role": "consumer",
    "estate": "both",
    "vault": "/home/YOU/vault/chronicler.db",
    "estates_dir": "/home/YOU/vault/estates"
  }
}
