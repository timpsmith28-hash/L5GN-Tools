#!/bin/sh
# L5GN-Tools -- the gate is the door. (Borrowed from Citadel v5 / CID.)
# Runs verify.py and refuses the commit if anything is red.
# Wired up with:  git config core.hooksPath .githooks
#
# Windows: Git for Windows runs this via its bundled bash. No chmod needed --
# mark it executable in git's INDEX instead:
#     git update-index --chmod=+x .githooks/pre-commit

if command -v python >/dev/null 2>&1; then
    PY=python
elif command -v py >/dev/null 2>&1; then
    PY=py
else
    echo "[pre-commit] ERROR: no 'python' or 'py' on PATH -- cannot run the gate."
    exit 1
fi

if [ ! -f verify.py ]; then
    echo "[pre-commit] NOTE: verify.py not present yet -- gate skipped (bootstrap)."
    exit 0
fi

echo "[pre-commit] running verify gate..."
"$PY" verify.py || {
    echo "[pre-commit] BLOCKED: verify is RED. Fix it, then commit."
    exit 1
}
echo "[pre-commit] verify GREEN -- commit allowed."
exit 0
